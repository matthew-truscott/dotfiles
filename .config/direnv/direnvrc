# Modern layout for uv projects
layout_uv() {
    # Use .venv in project root if it exists
    if [[ -d ".venv" ]]; then
        VIRTUAL_ENV="$(pwd)/.venv"
    else
        log_error "No .venv found. Run 'uv venv' first."
        return 1
    fi

    export VIRTUAL_ENV
    PATH_add "$VIRTUAL_ENV/bin"

    # Watch for dependency changes to prompt reload
    watch_file pyproject.toml
    watch_file uv.lock
}
